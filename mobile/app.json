{
  "expo": {
    "name": "NutriSnap AI",
    "slug": "nutrisnap-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nutrisnapai",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.leeon.nutrisnapai",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "NutriSnap AI uses your camera so you can take meal photos for nutrition estimates.",
        "NSPhotoLibraryUsageDescription": "NutriSnap AI uses your photo library so you can upload meal photos for nutrition estimates.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.leeon.nutrisnapai",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0B0B12",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0B0B12",
          "dark": {
            "backgroundColor": "#0B0B12"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "appEnvironment": "production",
      "router": {},
      "eas": {
        "projectId": "ce3dec69-2ccc-446c-86df-28daf13790d1"
      }
    }
  }
}
