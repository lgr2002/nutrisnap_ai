OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Options:
# fallback = no OpenAI cost, rule-based fallback only
# text = OpenAI text estimates only, ignores image input
# vision = OpenAI text + image estimates
AI_MODE=vision

APP_NAME=NutriSnap AI Backend
APP_ENV=development
USE_OPENAI=true